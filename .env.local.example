# ─────────────────────────────────────────────────────────────────────────────
# MemeVault — copy this file to ".env.local" and fill in your values.
#
# Firebase Storage  →  stores audio MP3 files (CDN-backed)
# MongoDB Atlas     →  stores metadata, likes, dislikes, download counts
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (Storage for audio files) ───────────────────────────────────────
# Firebase Console → Project Settings → Your apps → SDK setup & configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── MongoDB Atlas (metadata: likes, dislikes, downloads, sound URLs) ──────────
# MongoDB Atlas → Connect → Drivers → Node.js
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/memevault
MONGODB_URI=
